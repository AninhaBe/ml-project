# Mercado Livre OAuth
ML_CLIENT_ID=seu_app_id_aqui
ML_CLIENT_SECRET=<sua_chave_secreta_do_devcenter>
ML_REDIRECT_URI=https://webhook.site/SEU-UUID
# Será preenchido após rodar scripts/oauth_bootstrap.py
ML_REFRESH_TOKEN=

# Anthropic Claude
ANTHROPIC_API_KEY=<CHAVE_DA_ANTHROPIC>
# Modelo usado para extração de catálogos (Vision fallback nas páginas problemáticas)
# haiku-4-5: ~10x mais barato que sonnet, suficiente para extração estruturada
# sonnet-4-5: mais preciso, use se haiku errar nomes/preços
CLAUDE_VISION_MODEL=claude-haiku-4-5

# Parâmetros de cálculo de margem (ajuste conforme seu negócio)
TAXA_ML_CLASSICO=0.115
TAXA_ML_PREMIUM=0.165
ALIQUOTA_IMPOSTO=0.06
FRETE_FIXO=20.00
CUSTOS_EXTRAS=2.00
MARGEM_MINIMA=0.13
